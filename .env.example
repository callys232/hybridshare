# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hybridshare"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-64-char-random-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Leave blank to use built-in Next.js API routes (recommended)
# Set to an external server URL only when running a separate backend
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_MOCK_MODE="false"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="HybridShare <no-reply@hybridshare.io>"

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_STARTER_MONTHLY="price_xxxx"
STRIPE_PRICE_STARTER_YEARLY="price_xxxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxxx"
STRIPE_PRICE_PRO_YEARLY="price_xxxx"
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_xxxx"
STRIPE_PRICE_ENTERPRISE_YEARLY="price_xxxx"

# Cloud Storage add-on prices (one per base plan tier)
STRIPE_PRICE_CLOUD_FREE="price_xxxx"
STRIPE_PRICE_CLOUD_STARTER="price_xxxx"
STRIPE_PRICE_CLOUD_PRO="price_xxxx"
STRIPE_PRICE_CLOUD_ENTERPRISE="price_xxxx"

# ─── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# AWS S3 / Cloudflare R2 (required when cloud add-on is enabled)
AWS_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="hybridshare-files"
# For Cloudflare R2: override with your R2 endpoint URL
# STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# ─── Nginx / CDN ───────────────────────────────────────────────────────────────
NGINX_DOMAIN=""
APP_URL="http://localhost:3000"
