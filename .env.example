# ── API ─────────────────────────────────────────────────────────────────────
# URL of the running API server (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public URL of this web app (used in share links, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to bypass the real API and use local mock data
NEXT_PUBLIC_MOCK_MODE=false

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Nginx / Production domain ────────────────────────────────────────────────
# Your production domain (used in next.config.mjs for image optimisation)
NGINX_DOMAIN=yourdomain.com
APP_URL=https://yourdomain.com
