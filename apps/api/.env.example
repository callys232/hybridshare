# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hybridshare
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# ─── Object Storage (MinIO / S3-compatible) ───────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hybridshare
MINIO_REGION=us-east-1

# ─── Search ───────────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_string_minimum_32_chars_required
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
TOTP_ISSUER=HybridShare

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64-char hex (32 bytes) — used to encrypt connector credentials at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=replace_with_exactly_64_hex_chars_for_aes256_encryption

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@hybridshare.io

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# ─── Microsoft OAuth ──────────────────────────────────────────────────────────
# MICROSOFT_CLIENT_ID=your_microsoft_client_id
# MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# MICROSOFT_TENANT_ID=common
# MICROSOFT_CALLBACK_URL=http://localhost:4000/api/auth/oauth/microsoft/callback

# ─── LDAP / Active Directory ──────────────────────────────────────────────────
# LDAP_URL=ldap://your-dc.company.com
# LDAP_BIND_DN=CN=service-account,DC=company,DC=com
# LDAP_BIND_CREDENTIALS=password
# LDAP_SEARCH_BASE=DC=company,DC=com
# LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# ─── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AI (Anthropic / Claude) ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── PDF Generation ───────────────────────────────────────────────────────────
# Leave blank to use Puppeteer's bundled Chromium
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ─── Virus Scanning (ClamAV) ──────────────────────────────────────────────────
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310

# ─── Video / CDN (optional) ───────────────────────────────────────────────────
# BUNNY_CDN_API_KEY=
# BUNNY_CDN_STORAGE_ZONE=
# MUXDATA_TOKEN_ID=
# MUXDATA_TOKEN_SECRET=

# ─── Live Sessions (optional) ─────────────────────────────────────────────────
# ZOOM_API_KEY=
# ZOOM_API_SECRET=
# DAILY_CO_API_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── File Uploads ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
MAX_UPLOAD_SIZE_MB=500
ALLOWED_MIME_TYPES=*

# ─── Connectors ───────────────────────────────────────────────────────────────
CONNECTOR_SYNC_INTERVAL_MINUTES=60
CONNECTOR_MAX_RETRIES=3

# ─── LMS / Certificates ───────────────────────────────────────────────────────
CERTIFICATE_ISSUER=HybridShare
SCORM_STORAGE_BUCKET=hybridshare-scorm
